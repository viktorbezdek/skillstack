{
  "$schema": "https://design-tokens.github.io/community-group/format.json",
  "color": {
    "$type": "color",
    "primary": {
      "$value": "#0066cc",
      "$description": "Primary brand color"
    },
    "secondary": {
      "$value": "#6c757d",
      "$description": "Secondary color for less prominent elements"
    },
    "success": {
      "$value": "#28a745",
      "$description": "Success state color"
    },
    "error": {
      "$value": "#dc3545",
      "$description": "Error state color"
    },
    "warning": {
      "$value": "#ffc107",
      "$description": "Warning state color"
    },
    "info": {
      "$value": "#17a2b8",
      "$description": "Informational color"
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": {
      "$value": "4px",
      "$description": "Extra small spacing"
    },
    "sm": {
      "$value": "8px",
      "$description": "Small spacing"
    },
    "md": {
      "$value": "16px",
      "$description": "Medium spacing"
    },
    "lg": {
      "$value": "24px",
      "$description": "Large spacing"
    },
    "xl": {
      "$value": "32px",
      "$description": "Extra large spacing"
    }
  },
  "typography": {
    "font-family": {
      "$type": "fontFamily",
      "body": {
        "$value": ["Inter", "system-ui", "sans-serif"],
        "$description": "Font family for body text"
      },
      "heading": {
        "$value": ["Helvetica Neue", "Helvetica", "Arial", "sans-serif"],
        "$description": "Font family for headings"
      },
      "monospace": {
        "$value": ["Monaco", "Consolas", "monospace"],
        "$description": "Font family for code"
      }
    },
    "font-size": {
      "$type": "dimension",
      "xs": {
        "$value": "12px"
      },
      "sm": {
        "$value": "14px"
      },
      "md": {
        "$value": "16px"
      },
      "lg": {
        "$value": "18px"
      },
      "xl": {
        "$value": "20px"
      },
      "2xl": {
        "$value": "24px"
      },
      "3xl": {
        "$value": "30px"
      },
      "4xl": {
        "$value": "36px"
      }
    },
    "font-weight": {
      "$type": "fontWeight",
      "normal": {
        "$value": 400
      },
      "medium": {
        "$value": 500
      },
      "semibold": {
        "$value": 600
      },
      "bold": {
        "$value": 700
      }
    },
    "line-height": {
      "$type": "number",
      "tight": {
        "$value": 1.25
      },
      "normal": {
        "$value": 1.5
      },
      "relaxed": {
        "$value": 1.75
      }
    }
  },
  "shadow": {
    "$type": "shadow",
    "sm": {
      "$value": {
        "offsetX": "0px",
        "offsetY": "1px",
        "blur": "2px",
        "spread": "0px",
        "color": "rgba(0, 0, 0, 0.05)"
      }
    },
    "md": {
      "$value": {
        "offsetX": "0px",
        "offsetY": "4px",
        "blur": "6px",
        "spread": "-1px",
        "color": "rgba(0, 0, 0, 0.1)"
      }
    },
    "lg": {
      "$value": {
        "offsetX": "0px",
        "offsetY": "10px",
        "blur": "15px",
        "spread": "-3px",
        "color": "rgba(0, 0, 0, 0.1)"
      }
    }
  },
  "border": {
    "radius": {
      "$type": "dimension",
      "sm": {
        "$value": "4px"
      },
      "md": {
        "$value": "8px"
      },
      "lg": {
        "$value": "12px"
      },
      "full": {
        "$value": "9999px"
      }
    }
  },
  "animation": {
    "duration": {
      "$type": "duration",
      "fast": {
        "$value": "150ms"
      },
      "normal": {
        "$value": "300ms"
      },
      "slow": {
        "$value": "500ms"
      }
    },
    "easing": {
      "$type": "cubicBezier",
      "ease-in": {
        "$value": [0.42, 0, 1, 1]
      },
      "ease-out": {
        "$value": [0, 0, 0.58, 1]
      },
      "ease-in-out": {
        "$value": [0.42, 0, 0.58, 1]
      }
    }
  }
}
